GPC_POSTGRES_USER=gpc
GPC_POSTGRES_PASSWORD=gpcpass
GPC_POSTGRES_DB=gpc
GPC_POSTGRES_PORT=5433

GPC_QDRANT_HOST=localhost
GPC_QDRANT_PORT=6333
GPC_QDRANT_HTTP_PORT=6333
GPC_QDRANT_GRPC_PORT=6334

GPC_EMBEDDING_PROVIDER=ollama
GPC_OLLAMA_HOST=http://localhost:11434
GPC_OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
GPC_OLLAMA_TIMEOUT_SECONDS=60
# Leave as 0 to detect dimensions from the active Ollama embedding model.
GPC_VECTOR_SIZE=0

GPC_POSTGRES_DSN=postgresql://gpc:gpcpass@localhost:5433/gpc

GPC_NEO4J_URI=bolt://localhost:7687
GPC_NEO4J_USER=neo4j
GPC_NEO4J_PASSWORD=gpcneo4jpass
GPC_NEO4J_BROWSER_PORT=7474
GPC_NEO4J_BOLT_PORT=7687

# Optional Graphify -> Neo4j project graph sync.
# Neo4j Community uses one database; projects and repos are separated by
# project_slug and repo_slug inside the graph.
GPC_GRAPHIFY_ENABLED=1
GPC_GRAPHIFY_PROJECT_SLUG=
GPC_GRAPHIFY_REPO_SLUG=
GPC_GRAPHIFY_LOG=.gpc/graphify-neo4j.log
GPC_GRAPHIFY_GRAPH_PATH=graphify-out/graph.json
GPC_GRAPHIFY_NEO4J_URI=bolt://localhost:7687
GPC_GRAPHIFY_NEO4J_USER=neo4j
GPC_GRAPHIFY_NEO4J_PASSWORD=gpcneo4jpass
GPC_GRAPHIFY_NEO4J_PYTHON=
GPC_GRAPHIFY_NEO4J_CLEAR_REPO=1

GPC_MCP_HTTP_HOST=127.0.0.1
GPC_MCP_HTTP_PORT=8765
GPC_MCP_HTTP_PATH=/mcp

GPC_GRAFANA_PORT=3000
GPC_GRAFANA_ADMIN_USER=admin
GPC_GRAFANA_ADMIN_PASSWORD=gpcgrafanapass
